<group name="cisco_meraki,">

  <rule id="110500" level="3">
    <decoded_as>meraki</decoded_as>
    <description>Cisco Meraki event detected</description>
  </rule>

  <rule id="110501" level="5">
    <if_sid>110500</if_sid>
    <match>events content_filtering_block</match>
    <description>Cisco Meraki content filtering block</description>
    <group>content_filtering,</group>
  </rule>

  <rule id="110502" level="8">
    <if_sid>110500</if_sid>
    <match>events type=device_packet_flood</match>
    <description>Cisco Meraki wireless device packet flood detected</description>
    <group>wireless,dos,</group>
  </rule>

  <rule id="110503" level="8">
    <if_sid>110500</if_sid>
    <match>events type=packet_flood</match>
    <description>Cisco Meraki wireless packet flood detected</description>
    <group>wireless,dos,</group>
  </rule>

  <rule id="110504" level="4">
    <if_sid>110500</if_sid>
    <match>events dhcp lease</match>
    <description>Cisco Meraki DHCP lease assigned</description>
    <group>dhcp,</group>
  </rule>

  <rule id="110505" level="4">
    <if_sid>110500</if_sid>
    <match>events type=association</match>
    <description>Cisco Meraki wireless client association</description>
    <group>wireless,authentication,</group>
  </rule>

  <rule id="110506" level="4">
    <if_sid>110500</if_sid>
    <match>events type=wpa_auth</match>
    <description>Cisco Meraki WPA authentication</description>
    <group>wireless,authentication,</group>
  </rule>

  <rule id="110507" level="6">
    <if_sid>110500</if_sid>
    <match>events type=wpa_deauth</match>
    <description>Cisco Meraki WPA deauthentication</description>
    <group>wireless,authentication,</group>
  </rule>

  <rule id="110508" level="5">
    <if_sid>110500</if_sid>
    <match>events type=disassociation</match>
    <description>Cisco Meraki wireless client disassociation</description>
    <group>wireless,</group>
  </rule>

  <rule id="110509" level="6">
    <if_sid>110500</if_sid>
    <match>events dhcp no offers</match>
    <description>Cisco Meraki DHCP no offers event</description>
    <group>dhcp,network,</group>
  </rule>

  <rule id="110510" level="7">
    <if_sid>110500</if_sid>
    <match>events type=martian_vlan</match>
    <description>Cisco Meraki martian VLAN traffic detected</description>
    <group>network,</group>
  </rule>

  <rule id="110511" level="5">
    <if_sid>110500</if_sid>
    <match>events type=fips_event</match>
    <description>Cisco Meraki FIPS event</description>
    <group>security,</group>
  </rule>

  <rule id="110512" level="5">
    <if_sid>110500</if_sid>
    <match>events port </match>
    <description>Cisco Meraki switch port status event</description>
    <group>switch,network,</group>
  </rule>

  <rule id="110599" level="5">
    <if_sid>110500</if_sid>
    <description>Cisco Meraki unclassified event - review parser coverage</description>
    <group>unclassified,</group>
  </rule>

</group>
